# Copy this file to .env and fill in values from `cdk deploy` outputs
# (infrastructure/README or docs/DEPLOYMENT.md).

# API Gateway base URL, e.g. https://abc123.execute-api.us-east-1.amazonaws.com/prod
VITE_API_URL=http://localhost:8000

# AWS region the stack was deployed to
VITE_AWS_REGION=us-east-1

# Cognito User Pool + App Client IDs.
# Leave blank to run with the original localStorage-only mock auth
# (useful for local UI development without any AWS resources deployed).
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
