# AWS account/region used by `cdk deploy`. CDK also reads these from your
# configured AWS CLI profile (`aws configure`) if not set here.
CDK_DEFAULT_ACCOUNT=123456789012
CDK_DEFAULT_REGION=us-east-1

# Bedrock model used by the chat Lambda. Must be enabled for your account
# in the Bedrock console (Model access) before /chat will return live
# responses; otherwise the endpoint returns a graceful fallback message.
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0
